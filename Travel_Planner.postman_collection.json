{
  "info": {
    "name": "Travel Planner API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Full API collection for Travel Planner. Set base_url variable to http://localhost:8000"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "token", "value": "" },
    { "key": "project_id", "value": "" },
    { "key": "place_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john\",\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('token', json.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "john" },
                { "key": "password", "value": "secret123" }
              ]
            }
          }
        },
        {
          "name": "Me (current user)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create project (no places)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('project_id', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/projects", "host": ["{{base_url}}"], "path": ["projects"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Paris Trip\",\n  \"description\": \"Visiting museums and galleries\",\n  \"start_date\": \"2025-06-01\"\n}"
            }
          }
        },
        {
          "name": "Create project (with places from API)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('project_id', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/projects", "host": ["{{base_url}}"], "path": ["projects"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Art Tour\",\n  \"description\": \"Famous artworks\",\n  \"place_ids\": [27992, 28560]\n}"
            }
          }
        },
        {
          "name": "List projects",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/projects?page=1&size=20",
              "host": ["{{base_url}}"],
              "path": ["projects"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "size", "value": "20" },
                { "key": "status", "value": "active", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get project by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/projects/{{project_id}}", "host": ["{{base_url}}"], "path": ["projects", "{{project_id}}"] }
          }
        },
        {
          "name": "Update project",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/projects/{{project_id}}", "host": ["{{base_url}}"], "path": ["projects", "{{project_id}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Trip Name\",\n  \"description\": \"Updated description\"\n}"
            }
          }
        },
        {
          "name": "Delete project",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/projects/{{project_id}}", "host": ["{{base_url}}"], "path": ["projects", "{{project_id}}"] }
          }
        },
        {
          "name": "Delete project (blocked — has visited place)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/projects/{{project_id}}", "host": ["{{base_url}}"], "path": ["projects", "{{project_id}}"] },
            "description": "Returns 409 if any place in the project is already visited"
          }
        }
      ]
    },
    {
      "name": "Places",
      "item": [
        {
          "name": "Add place to project",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('place_id', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}/places",
              "host": ["{{base_url}}"],
              "path": ["projects", "{{project_id}}", "places"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"external_id\": 27992,\n  \"notes\": \"Must see the water lilies!\"\n}"
            }
          }
        },
        {
          "name": "Add place — invalid ID (422)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}/places",
              "host": ["{{base_url}}"],
              "path": ["projects", "{{project_id}}", "places"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"external_id\": 999999999\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Returns 422 — artwork not found in Art Institute API"
          }
        },
        {
          "name": "List places in project",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}/places?page=1&size=20",
              "host": ["{{base_url}}"],
              "path": ["projects", "{{project_id}}", "places"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get single place",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}/places/{{place_id}}",
              "host": ["{{base_url}}"],
              "path": ["projects", "{{project_id}}", "places", "{{place_id}}"]
            }
          }
        },
        {
          "name": "Update place notes",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}/places/{{place_id}}",
              "host": ["{{base_url}}"],
              "path": ["projects", "{{project_id}}", "places", "{{place_id}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Visited on a Tuesday, amazing experience!\"\n}"
            }
          }
        },
        {
          "name": "Mark place as visited",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}/places/{{place_id}}",
              "host": ["{{base_url}}"],
              "path": ["projects", "{{project_id}}", "places", "{{place_id}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"visited\": true\n}",
              "description": "When all places in project are visited, project status becomes 'completed' automatically"
            }
          }
        }
      ]
    }
  ]
}
